# Production .htaccess — lives at the web root (public_html/) after deploy.
# Vite copies everything in frontend/public/ into frontend/dist/ during build,
# and deploy-https.yml unpacks dist/* into public_html/.

RewriteEngine On

# ── SPA routing ──────────────────────────────────────────────────────────────
# Real files and directories are served as-is (assets, models, default-*.png,
# backend/*.php, uploads/*, etc). Everything else falls through to index.html
# so react-router can handle the URL on a full-page load or refresh.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Backend API is PHP — never rewrite it.
RewriteRule ^backend/ - [L]

# All remaining paths → SPA entry point.
RewriteRule ^ index.html [L]

# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml application/wasm
    AddOutputFilterByType DEFLATE font/ttf font/otf application/vnd.ms-fontobject
    SetEnvIfNoCase Request_URI \.(?:jpg|jpeg|png|gif|webp|ico|mp4|webm|zip|gz)$ no-gzip
</IfModule>

# ── Cache policy ─────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 hour"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 30 days"
    ExpiresByType image/webp                    "access plus 30 days"
    ExpiresByType image/jpeg                    "access plus 30 days"
    ExpiresByType image/png                     "access plus 30 days"
    ExpiresByType image/gif                     "access plus 30 days"
    ExpiresByType image/x-icon                  "access plus 30 days"
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType application/json              "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Vite content-hashed assets — immutable
    <FilesMatch "\.[0-9a-f]{8,}\.(js|css|woff2|svg|png|jpg|jpeg|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # index.html must NEVER be long-cached
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Misc ─────────────────────────────────────────────────────────────────────
Options -Indexes

<FilesMatch "\.(sql|log|env|zip|tar|bak|ini|conf)$">
    Require all denied
</FilesMatch>

AddDefaultCharset UTF-8
