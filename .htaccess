RewriteEngine On

# ═════════════════════════════════════════════════════════════════════════════
# SPA ROUTING (don't touch: already working)
# ═════════════════════════════════════════════════════════════════════════════

# Don't rewrite existing files/dirs (backend, uploads, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Don't rewrite backend API calls
RewriteRule ^backend/ - [L]

# Rewrite assets to frontend/dist/assets (also handles /subroute/assets/ from relative base)
RewriteRule ^(?:[^/]+/)?assets/(.*)$ frontend/dist/assets/$1 [L]

# Rewrite models to frontend/dist/models (also handles /subroute/models/)
RewriteRule ^(?:[^/]+/)?models/(.*)$ frontend/dist/models/$1 [L]

# Route all other requests to React SPA
RewriteRule ^ frontend/dist/index.html [L]

# ═════════════════════════════════════════════════════════════════════════════
# COMPRESSION (gzip for anything text-ish; 60-85% size reduction on JS/CSS)
# ═════════════════════════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml application/wasm
    AddOutputFilterByType DEFLATE font/ttf font/otf application/vnd.ms-fontobject
    # Don't re-compress already-compressed formats
    SetEnvIfNoCase Request_URI \.(?:jpg|jpeg|png|gif|webp|ico|mp4|webm|zip|gz)$ no-gzip
</IfModule>

# ═════════════════════════════════════════════════════════════════════════════
# BROWSER CACHE — by file type
# ═════════════════════════════════════════════════════════════════════════════
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 hour"

    # Hashed build artifacts (Vite outputs content-hashed filenames) — cache forever
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 30 days"

    # User-uploaded photos (thumbnails change rarely; originals never)
    ExpiresByType image/webp                    "access plus 30 days"
    ExpiresByType image/jpeg                    "access plus 30 days"
    ExpiresByType image/png                     "access plus 30 days"
    ExpiresByType image/gif                     "access plus 30 days"
    ExpiresByType image/x-icon                  "access plus 30 days"

    # HTML must never long-cache — new deploys need to take effect instantly
    ExpiresByType text/html                     "access plus 0 seconds"

    # API responses ride on their own Cache-Control headers set in PHP
    ExpiresByType application/json              "access plus 0 seconds"
</IfModule>

# ═════════════════════════════════════════════════════════════════════════════
# EXPLICIT CACHE-CONTROL — overrides default for specific paths
# ═════════════════════════════════════════════════════════════════════════════
<IfModule mod_headers.c>
    # Vite-hashed assets: immutable = browser won't even revalidate (it can't change)
    <FilesMatch "\.[0-9a-f]{8,}\.(js|css|woff2|svg|png|jpg|jpeg|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Everything under /assets/ (Vite output dir) — long cache
    # LocationMatch isn't allowed in .htaccess, so use SetEnvIf + env-conditional Header
    SetEnvIf Request_URI "^/(matrimony/)?(frontend/dist/)?assets/" long_cache
    Header set Cache-Control "public, max-age=31536000, immutable" env=long_cache

    # User uploads — 30 days, allow revalidation
    SetEnvIf Request_URI "^/(matrimony/)?(backend/api/)?uploads/" uploads_cache
    Header set Cache-Control "public, max-age=2592000" env=uploads_cache

    # index.html MUST NOT be cached (contains script tags referencing the latest build)
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Security headers (defense in depth; Cloudflare adds more at edge)
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ═════════════════════════════════════════════════════════════════════════════
# SAFETY / HOUSEKEEPING
# ═════════════════════════════════════════════════════════════════════════════

# No directory listings
Options -Indexes

# Serve the SPA index when accessing the app root as a directory
DirectoryIndex frontend/dist/index.html index.html

# Block access to source/config files
<FilesMatch "\.(sql|log|env|zip|tar|bak|ini|conf)$">
    Require all denied
</FilesMatch>

# Default charset
AddDefaultCharset UTF-8
